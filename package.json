{
  "name": "chief-of-staff-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "build": "npm run build --workspace client",
    "start": "node server.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
